meta {
  name: Create Murugan Stores
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/shops
  body: json
  auth: none
}

body:json {
  {
    "name": "Murugan Stores",
    "ownerName": "Murugan Krishnan",
    "location": "Chennai",
    "phone": "9876543210"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("muruganShopId", res.body.id);
  }
}
