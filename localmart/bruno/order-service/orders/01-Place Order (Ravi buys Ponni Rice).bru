meta {
  name: Place Order - Ravi buys Ponni Rice
  type: http
  seq: 1
}

post {
  url: {{order_base_url}}/api/orders
  body: json
  auth: none
}

body:json {
  {
    "userId": "{{lastUserId}}",
    "shopId": "{{muruganShopId}}",
    "productId": "{{lastProductId}}",
    "quantity": 2
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("lastOrderId", res.body.id);
  }
}
