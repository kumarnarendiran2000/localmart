meta {
  name: Register Customer - Ravi
  type: http
  seq: 1
}

post {
  url: {{user_base_url}}/api/users
  body: json
  auth: none
}

body:json {
  {
    "name": "Ravi Kumar",
    "email": "ravi.kumar@gmail.com",
    "phone": "9876543210",
    "address": "42, Anna Nagar, Chennai",
    "role": "CUSTOMER"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("lastUserId", res.body.id);
  }
}
